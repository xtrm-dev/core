{
  "id": "beads",
  "description": "Issue tracking enforcement — edit gate (claim required), commit gate (close before commit), stop gate (no unclosed claims), memory gate (persist insights), compact save/restore.",
  "version": "1",
  "runtime": "both",
  "order": 20,
  "claude": {
    "hooks": [
      {
        "event": "SessionStart",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/beads-compact-restore.mjs",
        "timeout": 5000
      },
      {
        "event": "PreToolUse",
        "matcher": "$WRITE_TOOLS",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/beads-edit-gate.mjs",
        "timeout": 5000
      },
      {
        "event": "PreToolUse",
        "matcher": "Bash",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/beads-commit-gate.mjs",
        "timeout": 5000
      },
      {
        "event": "Stop",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/beads-memory-gate.mjs",
        "timeout": 8000
      },
      {
        "event": "PreCompact",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/beads-compact-save.mjs",
        "timeout": 5000
      }
    ]
  },
  "pi": {
    "extension": "packages/pi-extensions/extensions/beads/index.ts",
    "events": [
      "session_start",
      "tool_call",
      "tool_result",
      "agent_end",
      "session_shutdown"
    ]
  }
}
