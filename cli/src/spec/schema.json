{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "validated",
        "planned",
        "archived"
      ]
    },
    "scrutiny": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "problem": {
      "type": "string",
      "minLength": 1
    },
    "success": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope": {
      "type": "object",
      "properties": {
        "include": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exclude": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "include",
        "exclude"
      ],
      "additionalProperties": false
    },
    "non_goals": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requirements": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^R\\d+$"
          },
          "story": {
            "type": "string",
            "minLength": 1
          },
          "behavior": {
            "type": "string",
            "minLength": 1
          },
          "acceptance": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "layer_hint": {
            "type": "string",
            "enum": [
              "core",
              "boundary",
              "shell",
              "operational"
            ]
          },
          "priority": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4
          },
          "risks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "story",
          "behavior",
          "acceptance"
        ],
        "additionalProperties": false
      }
    },
    "validation": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "unit",
              "integration",
              "smoke",
              "e2e",
              "telemetry"
            ]
          },
          "target": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "kind",
          "target"
        ],
        "additionalProperties": false
      }
    },
    "dependencies": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "pattern": "^R\\d+$"
          },
          "requires": {
            "type": "string",
            "pattern": "^R\\d+$"
          }
        },
        "required": [
          "from",
          "requires"
        ],
        "additionalProperties": false
      }
    },
    "open_questions": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "default": {
        "children": [],
        "test_issues": []
      },
      "type": "object",
      "properties": {
        "parent_epic": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "planner_bead": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "epic": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "children": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "test_issues": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "children",
        "test_issues"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "schema_version",
    "id",
    "title",
    "status",
    "scrutiny",
    "problem",
    "success",
    "scope",
    "non_goals",
    "constraints",
    "requirements",
    "validation",
    "dependencies",
    "open_questions",
    "links"
  ],
  "additionalProperties": false,
  "$id": "https://xtrm.dev/schemas/spec-v1.json",
  "title": "xtrm spec.yaml v1",
  "description": "Versioned intent artifact for xt spec. PRD-level inputs that compile to a planner bead via xt spec apply."
}
