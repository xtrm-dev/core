{
  "name": "xtrm-tools",
  "version": "0.7.14",
  "description": "Claude Code tools installer (skills, hooks, MCP servers)",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "cli",
    "packages/pi-extensions"
  ],
  "bin": {
    "xtrm": "cli/dist/index.cjs",
    "xt": "cli/dist/index.cjs",
    "ghgrep": "scripts/ghgrep.mjs"
  },
  "files": [
    "README.md",
    "CHANGELOG.md",
    "cli/dist",
    "cli/package.json",
    "scripts/ghgrep.mjs",
    "scripts/patch-external-pi-tools.mjs",
    ".xtrm/config",
    ".xtrm/hooks",
    "packages/pi-extensions",
    ".xtrm/skills/default",
    ".xtrm/skills/optional",
    ".xtrm/registry.json",
    "!**/__pycache__/**",
    "!**/*.pyc",
    "!.xtrm/hooks/tsconfig-cache.json",
    "!packages/pi-extensions/extensions/**/.pi/**",
    "!.xtrm/extensions/**/.pi/**",
    "!.xtrm/**/test_*.py",
    "!.xtrm/**/tests/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jaggerxtrm/xtrm-tools.git"
  },
  "homepage": "https://github.com/Jaggerxtrm/xtrm-tools#readme",
  "bugs": {
    "url": "https://github.com/Jaggerxtrm/xtrm-tools/issues"
  },
  "scripts": {
    "sync:cli-version": "node scripts/sync-cli-version.mjs",
    "compile-policies": "node scripts/compile-policies.mjs",
    "check-policies": "node scripts/compile-policies.mjs --check",
    "check-pi": "node scripts/compile-policies.mjs --check-pi",
    "prebuild": "npm run sync:cli-version",
    "build": "npm run build --workspace cli",
    "typecheck": "npm run typecheck --workspace cli",
    "start": "node cli/dist/index.cjs",
    "lint": "echo 'No linting configured'",
    "test": "npm test --workspace cli",
    "version": "npm run sync:cli-version && git add cli/package.json packages/pi-extensions/package.json",
    "prepublishOnly": "npm run sync:cli-version && node scripts/vendor-specialists-skills.mjs && npm run gen-registry && npm run build",
    "release": "npm publish --tag latest",
    "release:pi-extensions": "npm publish --workspace @jaggerxtrm/pi-extensions --tag latest --access public",
    "release:all": "npm run release && npm run release:pi-extensions",
    "gen-registry": "node scripts/gen-registry.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@artale/pi-procs": "^1.1.0",
    "comment-json": "^4.2.3",
    "conf": "^15.1.0",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.2.0",
    "kleur": "^4.1.5",
    "prompts": "^2.4.2",
    "xtrm-tools": "^2.0.2"
  },
  "pi": {
    "extensions": [
      "./packages/pi-extensions"
    ],
    "packages": [
      "npm:pi-gitnexus",
      "npm:pi-serena-tools",
      "npm:@zenobius/pi-worktrees",
      "npm:@robhowley/pi-structured-return",
      "npm:@aliou/pi-guardrails",
      "npm:@aliou/pi-processes"
    ]
  }
}
