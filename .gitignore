.DS_Store
__pycache__/
*.py[cod]
.Python
venv/
.venv/
node_modules/
.vscode/
.idea/
*.swp
*.log
cli/node_modules
/vsync_repo
.gitnexus
.dmux/

# Dolt database files (added by bd init)
.dolt/
*.db

# TDD Guard runtime data
.claude/tdd-guard/data/

# Pi npm cache (symlink AND directory forms — executors sometimes create as symlink to abs path)
.pi/npm
.pi/npm/

# pnpm-workspace.yaml: generated by pnpm when invoked inside this npm-workspaces
# repo (specialist tooling occasionally shells out to pnpm in worktrees). Not
# part of xtrm-tools. Without this, executor checkpoint commits silently stage
# stray pnpm-workspace.yaml into chain branches (xtrm-ombq).
pnpm-workspace.yaml
cli/pnpm-workspace.yaml

# Skill eval workspaces (local eval artifacts, not for review)
skills/*-workspace/
.xtrm/skills/default/*-workspace/

# Git worktrees (managed by Claude Code)
.claude/worktrees/
.worktrees/
.xtrm/worktrees/
.xtrm/statusline-claim
.xtrm/debug.db
.xtrm-session-state.json
.session-meta.json
.xtrm/session-meta.json
.claude/skills/

.perles/

# bv (beads viewer) local config and caches
.bv/

.specialists/jobs/
.specialists/ready/
.specialists/trace.jsonl
packages/pi-extensions/extensions/xtrm-ui/.serena/
.xtrm/extensions/**/.pi/

# Beads runtime files (always modified, not meaningful to track)
.beads/dolt-monitor.pid
.beads/dolt-server.activity

# Quality-gates hook runtime cache (accumulates local machine paths)
hooks/tsconfig-cache.json
.xtrm/hooks/tsconfig-cache.json
.xtrm/session-meta.json

# Project-level skills symlink (runtime artifact, installed by xtrm)
.claude/skills

# Claude Code per-session local overrides (written per-worktree by xt claude /
# xt pi). Caught by user-global gitignore on most dev machines but listed here
# for portability so CI and fresh clones agree it is never tracked.
.claude/settings.local.json

# Skills runtime views (generated by xt init — not source)
.xtrm/skills/active/

# Legacy agent skills path (deprecated, replaced by .xtrm/skills/active/)
.agents/

# Keep synthesized memory under version control
!.xtrm/memory.md

.specialists/db/*.db
.specialists/db/*.db-wal
.specialists/db/*.db-shm

# Serena project metadata for nested package workspaces
.xtrm/packages/pi-extensions/.serena/

# Beads / Dolt files (added by bd init)
.beads-credential-key

# Beads / Dolt files (added by bd init)
.beads/proxieddb/

# Local agent/runtime dotfile artifacts (generated per checkout, not source)
.claude/settings.json
.claude/service-registry.json
.pi/
.serena/
.wolf/
.mcp.json
.zed/
.codex
.smoke-test
.specialists/executor-result.md
.beads/interactions.jsonl

# Nested tool runtime folders
cli/.pi/
packages/*/.serena/
