#!/usr/bin/env bash
# Project-local pre-commit checks preserved by the security pipeline wrapper.
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
HOOK="$ROOT/.claude/git-hooks/doc_reminder.py"

if command -v python3 >/dev/null 2>&1 && [ -f "$HOOK" ]; then
    python3 "$HOOK" || true
fi
